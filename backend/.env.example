DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/test_knowledge_base
ANALYZER_PROVIDER=llm
AI_PARSE_PROVIDER=llm

# Config-driven provider chain
LLM_PROVIDER_CHAIN=main,backup,zhipu

LLM_PROVIDER_MAIN_TYPE=openai_compatible
LLM_PROVIDER_MAIN_API_KEY=your-openai-api-key-here
LLM_PROVIDER_MAIN_BASE_URL=https://api.routin.ai/v1
LLM_PROVIDER_MAIN_TEXT_MODEL=gpt-5.4
LLM_PROVIDER_MAIN_VISION_MODEL=gpt-5.4

LLM_PROVIDER_BACKUP_TYPE=openai_compatible
LLM_PROVIDER_BACKUP_API_KEY=your-openai-api-key-here
LLM_PROVIDER_BACKUP_BASE_URL=https://api.routin.ai/v1
LLM_PROVIDER_BACKUP_TEXT_MODEL=gpt-5.3-codex
LLM_PROVIDER_BACKUP_VISION_MODEL=gpt-5.3-codex

LLM_PROVIDER_ZHIPU_TYPE=zhipu
LLM_PROVIDER_ZHIPU_API_KEY=your-zhipu-api-key-here
LLM_PROVIDER_ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
LLM_PROVIDER_ZHIPU_TEXT_MODEL=glm-4.7
LLM_PROVIDER_ZHIPU_VISION_MODEL=glm-4.7
LLM_PROVIDER_ZHIPU_THINKING_TYPE=disabled

LLM_REQUEST_TIMEOUT=60
LLM_CONNECT_TIMEOUT=10
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=6000
LLM_TEMPERATURE=0.15
LLM_SEED=42
LLM_THINKING_TYPE=disabled

# Legacy compatibility for scripts/tools that still read OPENAI_* / ZHIPU_*
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.routin.ai/v1
OPENAI_API_URL=https://api.routin.ai/v1/chat/completions
OPENAI_TEXT_MODEL=gpt-5.4
OPENAI_VISION_MODEL=gpt-5.4

ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPU_TEXT_MODEL=glm-4.7
ZHIPU_VISION_MODEL=glm-4.7
