# ============================================================
# 生产环境配置模板
# 复制此文件为 /etc/smart-test-kb/backend.env 并填入真实值
# 权限设置: chmod 600 /etc/smart-test-kb/backend.env
# ============================================================

# ------------------------------------------------------------
# 应用
# ------------------------------------------------------------
APP_ENV=production

# ------------------------------------------------------------
# 数据库
# ------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://your-user:your-password@localhost:5432/your-database

# ------------------------------------------------------------
# CORS（逗号分隔的允许域名列表）
# 同域 Nginx 反代时留空或不设置，即不启用 CORS 中间件
# ------------------------------------------------------------
# CORS_ORIGINS=https://your-domain.com

# ------------------------------------------------------------
# AI / LLM 提供商
# ------------------------------------------------------------
ANALYZER_PROVIDER=llm
AI_PARSE_PROVIDER=llm

# LLM 提供商链（按顺序尝试，逗号分隔）
LLM_PROVIDER_CHAIN=main,backup,zhipu

# --- 主提供商 ---
LLM_PROVIDER_MAIN_TYPE=openai_compatible
LLM_PROVIDER_MAIN_API_KEY=your-api-key-here
LLM_PROVIDER_MAIN_BASE_URL=https://your-api-endpoint/v1
LLM_PROVIDER_MAIN_TEXT_MODEL=your-text-model
LLM_PROVIDER_MAIN_VISION_MODEL=your-vision-model

# --- 备用提供商 ---
LLM_PROVIDER_BACKUP_TYPE=openai_compatible
LLM_PROVIDER_BACKUP_API_KEY=your-api-key-here
LLM_PROVIDER_BACKUP_BASE_URL=https://your-api-endpoint/v1
LLM_PROVIDER_BACKUP_TEXT_MODEL=your-text-model
LLM_PROVIDER_BACKUP_VISION_MODEL=your-vision-model

# --- 智谱 AI ---
LLM_PROVIDER_ZHIPU_TYPE=zhipu
LLM_PROVIDER_ZHIPU_API_KEY=your-zhipu-key-here
LLM_PROVIDER_ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
LLM_PROVIDER_ZHIPU_TEXT_MODEL=your-zhipu-model
LLM_PROVIDER_ZHIPU_VISION_MODEL=your-zhipu-model
LLM_PROVIDER_ZHIPU_THINKING_TYPE=disabled

# --- LLM 全局参数 ---
LLM_REQUEST_TIMEOUT=120
LLM_CONNECT_TIMEOUT=10
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=6000
LLM_TEMPERATURE=0.15
LLM_SEED=42
LLM_THINKING_TYPE=disabled
